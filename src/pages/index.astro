<style>
	:root {
		--ink:    #0a0a0a;
		--muted:  #6b7280;
		--border: #e5e7eb;
		--bg:     #ffffff;
		--brand:  #0d4a4a;
		--serif:  'IBM Plex Serif', Georgia, serif;
		--mono:   'IBM Plex Mono', monospace;
	}

	*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
	html, body { height: 100%; }

	body {
		background: var(--bg);
		color: var(--ink);
		font-family: var(--serif);
		-webkit-font-smoothing: antialiased;
		line-height: 1.6;
	}

	/* ── Nav ── */
	header {
		position: sticky;
		top: 0;
		background: var(--bg);
		border-bottom: 1px solid var(--border);
		z-index: 10;
	}

	nav {
		max-width: 960px;
		margin: 0 auto;
		padding: 0 2rem;
		height: 3.5rem;
		display: flex;
		align-items: center;
		gap: 2rem;
	}

	.wordmark {
		display: flex;
		align-items: center;
		gap: 0.65rem;
		text-decoration: none;
		color: var(--ink);
		font-size: 1rem;
		font-weight: 400;
		letter-spacing: 0.2em;
		margin-right: auto;
	}

	.wordmark svg { height: 16px; width: auto; }

	nav a:not(.wordmark) {
		font-size: 0.8rem;
		font-weight: 300;
		letter-spacing: 0.08em;
		text-decoration: none;
		color: var(--muted);
		text-transform: uppercase;
		transition: color 0.15s;
	}

	nav a:not(.wordmark):hover { color: var(--brand); }

	/* ── Main ── */
	main {
		max-width: 960px;
		margin: 0 auto;
		padding: 0 2rem;
	}

	/* ── Hero ── */
	.hero {
		padding: 8rem 0 5rem;
		border-bottom: 1px solid var(--border);
		margin-bottom: 5rem;
	}

	.hero h1 {
		font-size: clamp(4rem, 12vw, 8rem);
		font-weight: 300;
		letter-spacing: 0.3em;
		line-height: 1;
		margin-bottom: 2rem;
		color: var(--ink);
	}

	.tagline {
		font-size: clamp(1rem, 2.5vw, 1.2rem);
		font-weight: 300;
		color: var(--muted);
		line-height: 1.7;
		font-style: italic;
	}

	/* ── Content grid ── */
	.content {
		display: grid;
		grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
		gap: 4rem 5rem;
		padding-bottom: 8rem;
	}

	.block h2 {
		font-family: var(--mono);
		font-size: 0.7rem;
		font-weight: 400;
		text-transform: uppercase;
		letter-spacing: 0.12em;
		color: var(--muted);
		margin-bottom: 1rem;
	}

	.block p {
		font-size: 0.95rem;
		line-height: 1.75;
		margin-bottom: 0.75rem;
	}

	.link {
		font-size: 0.875rem;
		color: var(--brand);
		text-decoration: underline;
		text-underline-offset: 3px;
	}

	/* ── Footer ── */
	footer {
		border-top: 1px solid var(--border);
		padding: 1.5rem 2rem;
		max-width: 960px;
		margin: 0 auto;
		font-family: var(--mono);
		font-size: 0.7rem;
		letter-spacing: 0.15em;
		text-transform: uppercase;
		color: var(--muted);
	}
</style>

